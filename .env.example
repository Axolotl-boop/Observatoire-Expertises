# Authentification SSO Microsoft Entra (voir AUTH.md)
AUTH_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/<TENANT_ID>/v2.0
# URL stable de production (évite les mismatch de redirect URI sur Vercel)
AUTH_URL=https://<DOMAINE-VERCEL>

# Analytics maison (voir ANALYTICS.md) — injecté par l'intégration Postgres Vercel
DATABASE_URL=
# Emails autorisés à voir /admin/stats (séparés par des virgules)
ADMIN_EMAILS=axel.alizier@wefiit.com
# Rétention des événements en mois (purge auto via cron quotidien)
RETENTION_MONTHS=12
# Secret protégeant le cron de purge (Vercel l'envoie en en-tête Authorization)
CRON_SECRET=
